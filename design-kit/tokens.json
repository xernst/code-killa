{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "ink": {
      "950": { "$value": "#14140f", "$type": "color", "$description": "Page background — never pure black" },
      "900": { "$value": "#18181b", "$type": "color", "$description": "Card / panel fill" },
      "800": { "$value": "#27272a", "$type": "color", "$description": "Borders, dividers" },
      "700": { "$value": "#3f3f46", "$type": "color", "$description": "Decorative only — too dim for body text" },
      "500": { "$value": "#71717a", "$type": "color", "$description": "Tertiary UI labels" },
      "400": { "$value": "#a1a1aa", "$type": "color", "$description": "Secondary text on dark — meets WCAG AA" },
      "300": { "$value": "#d4d4d8", "$type": "color", "$description": "Body text on dark" },
      "100": { "$value": "#f4f4f5", "$type": "color", "$description": "Headlines on dark — never pure white" }
    },
    "ember": {
      "default": { "$value": "#2aa06a", "$type": "color", "$description": "Primary accent — caret, links, CTA" },
      "dim":     { "$value": "#1f7a51", "$type": "color", "$description": "Hover / active for ember" }
    },
    "semantic": {
      "ok":  { "$value": "#86efac", "$type": "color", "$description": "Success — used once, in pyodide output" },
      "err": { "$value": "#ef4444", "$type": "color", "$description": "Error — used once, in WEDGE bug highlight" }
    }
  },
  "font": {
    "family": {
      "display": { "$value": "Fraunces", "$type": "fontFamily", "$description": "Variable serif, opsz axis 144 for hero" },
      "mono":    { "$value": "JetBrains Mono", "$type": "fontFamily", "$description": "Code, labels, wordmark" }
    },
    "weight": {
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" },
      "black":     { "$value": 900, "$type": "fontWeight" }
    }
  },
  "tracking": {
    "display":  { "$value": "-0.04em", "$type": "letterSpacing" },
    "section":  { "$value": "-0.025em", "$type": "letterSpacing" },
    "body":     { "$value": "-0.005em", "$type": "letterSpacing" },
    "eyebrow":  { "$value": "0.4em", "$type": "letterSpacing" }
  },
  "duration": {
    "instant":  { "$value": "120ms", "$type": "duration" },
    "snap":     { "$value": "180ms", "$type": "duration" },
    "default":  { "$value": "300ms", "$type": "duration" },
    "entrance": { "$value": "600ms", "$type": "duration" },
    "hero":     { "$value": "900ms", "$type": "duration" }
  },
  "easing": {
    "slam":    { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",     "$type": "cubicBezier", "$description": "expo.out — sharp arrival" },
    "drift":   { "$value": "cubic-bezier(0.25, 1, 0.5, 1)",     "$type": "cubicBezier", "$description": "power3.out — confident" },
    "default": { "$value": "cubic-bezier(0.33, 1, 0.68, 1)",    "$type": "cubicBezier", "$description": "power2.out — neutral" },
    "pop":     { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "back.out(1.6) — overshoot" },
    "breathe": { "$value": "cubic-bezier(0.45, 0, 0.55, 1)",    "$type": "cubicBezier", "$description": "sine.inOut — ambient" }
  },
  "radius": {
    "sm": { "$value": "6px",  "$type": "dimension" },
    "md": { "$value": "10px", "$type": "dimension" },
    "lg": { "$value": "14px", "$type": "dimension" },
    "xl": { "$value": "20px", "$type": "dimension" }
  }
}
