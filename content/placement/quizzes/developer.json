      "options": [
        { "id": "a", "label": "6", "points": 2 },
        { "id": "b", "label": "24", "points": 0 },
        { "id": "c", "label": "Nothing, the function only prints", "points": 0 },
        { "id": "d", "label": "a + b", "points": 0 }
      ],
      "correctOptionId": "a"
    },
    {
      "id": "q04", "testsChapter": "02-functions", "type": "scenario", "concept": "no-return",
      "prompt": "A function does some work but has no return statement:",
      "code": "def greet(name):\n    print(\"hi \" + name)\n\nvalue = greet(\"Sam\")",
      "codeQuestion": "What is the value of value?",
      "options": [
        { "id": "a", "label": "None", "points": 2 },
        { "id": "b", "label": "\"hi Sam\"", "points": 1 },
        { "id": "c", "label": "\"Sam\"", "points": 0 },
        { "id": "d", "label": "An error", "points": 0 }
      ],
      "correctOptionId": "a"
