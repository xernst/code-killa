      "options": [
        { "id": "a", "label": "30", "points": 2 },
        { "id": "b", "label": "\"age\"", "points": 0 },
        { "id": "c", "label": "1, the position of age", "points": 0 },
        { "id": "d", "label": "An error", "points": 0 }
      ],
      "correctOptionId": "a"
    },
    {
      "id": "q06", "testsChapter": "03-lists-and-dicts", "type": "scenario", "concept": "list-index",
