    {
      "id": "q10", "testsChapter": "06-tracebacks", "type": "multiple-choice", "concept": "reading-tracebacks",
      "prompt": "When you get a long traceback, where is the most useful place to look first?",
      "options": [
        { "id": "a", "label": "The last line, which names the error type and message", "points": 2 },
        { "id": "b", "label": "The first line, and ignore the rest", "points": 0 },
        { "id": "c", "label": "It does not matter, tracebacks are random", "points": 0 },
        { "id": "d", "label": "The longest line", "points": 0 }
