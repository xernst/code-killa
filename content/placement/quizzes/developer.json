      "prompt": "A variable is set, then changed:",
      "code": "x = 5\nx = x + 3",
      "codeQuestion": "After both lines run, what is the value of x?",
      "options": [
        { "id": "a", "label": "8", "points": 2 },
        { "id": "b", "label": "5", "points": 0 },
        { "id": "c", "label": "3", "points": 0 },
        { "id": "d", "label": "An error, you cannot use x to set x", "points": 0 }
      ],
      "correctOptionId": "a"
    },
    {
      "id": "q02", "testsChapter": "01-variables", "type": "multiple-choice", "concept": "valid-names",
      "prompt": "Which of these is a valid Python variable name?",
