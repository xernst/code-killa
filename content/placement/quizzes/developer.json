        { "id": "a", "label": "second_place", "points": 2 },
        { "id": "b", "label": "2nd_place", "points": 0 },
        { "id": "c", "label": "second place", "points": 0 },
        { "id": "d", "label": "second-place", "points": 0 }
      ],
      "correctOptionId": "a"
