        { "id": "a", "label": "The code tried to read a dictionary key called 'email' that does not exist", "points": 2 },
        { "id": "b", "label": "The word 'email' is misspelled somewhere", "points": 0 },
        { "id": "c", "label": "An email failed to send", "points": 0 },
        { "id": "d", "label": "The 'email' key is locked and cannot be changed", "points": 0 }
