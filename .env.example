# Email subscription via Beehiiv
# Get these from https://app.beehiiv.com/settings:
#   - BEEHIIV_API_KEY: Settings → API → Create new API key
#   - BEEHIIV_PUBLICATION_ID: Settings → Publication → looks like "pub_xxxxxxxx-xxxx-..."
#
# Set both in Vercel: Project → Settings → Environment Variables (Production + Preview)
# Until set, the EmailSignup form on the landing page shows a graceful
# "subscription not configured yet" message instead of crashing.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
