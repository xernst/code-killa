# node / pnpm
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-error.log*

# capacitor build output
.capacitor/

# ios — keep ios/App/App/ source, ignore build artifacts + pods
ios/App/Pods/
ios/App/build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/
ios/Pods/

# android — keep source, ignore build artifacts
android/.gradle/
android/.idea/
android/app/build/
android/build/
android/captures/
android/local.properties
android/app/release/
android/app/debug/

# store binaries — never commit
*.ipa
*.aab
*.apk
*.dSYM.zip
*.xcarchive

# signing — NEVER commit these. losing a keystore means losing the android app forever.
*.keystore
*.jks
*.p8
*.p12
*.mobileprovision
*.cer
*.certSigningRequest

# env / secrets
.env
.env.*
!.env.example

# os crud
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/
*.swp
*.swo
